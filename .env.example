# ============================================================
# MediaHub – Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Server ───────────────────────────────────────────────────
SERVER_PORT=8080
GIN_MODE=debug                  # debug | release
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=60s

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=media_cms
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_MAX_LIFETIME=5m

# ── MinIO ─────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_DEFAULT_BUCKET=media
# Public URL served to clients (CDN, nginx proxy, or direct MinIO)
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
# How long signed URLs remain valid for private files
MINIO_SIGNED_URL_EXPIRY=1h

# ── JWT ───────────────────────────────────────────────────────
# Set AUTH_REQUIRED=true to enforce JWT on all /media routes.
# Leave false for the standalone CMS UI (no login flow needed).
AUTH_REQUIRED=false
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRY=24h

# ── Upload ────────────────────────────────────────────────────
# Max upload size in bytes (default: 100 MB)
UPLOAD_MAX_SIZE_BYTES=104857600

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
